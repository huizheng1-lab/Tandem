{
  "name": "tandem",
  "version": "0.1.0",
  "description": "Leader/worker AI coding agent TUI.",
  "type": "module",
  "main": "./out/main/index.js",
  "bin": {
    "tandem": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev:app": "electron-vite dev",
    "dist:app": "npm run build && electron-vite build && electron-builder && node scripts/stamp-app-build.mjs",
    "test": "vitest run --configLoader runner",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "2.0.85",
    "@ai-sdk/google": "^2.0.78",
    "@ai-sdk/openai": "2.0.110",
    "@ai-sdk/openai-compatible": "1.0.42",
    "ai": "5.0.210",
    "diff": "^8.0.2",
    "dotenv": "^17.2.3",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-cron": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.7",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "dev.tandem.app",
    "productName": "Tandem",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "win": {
      "icon": "app/assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
